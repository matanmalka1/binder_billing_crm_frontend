{
  "reporters": [
    "console"
  ],
  "pattern": "**/*.{ts,tsx}",
  "ignore": [
    "**/*.d.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/reports/**"
  ],
  "gitignore": true,
  "min-lines": 5,
  "min-tokens": 50
}
